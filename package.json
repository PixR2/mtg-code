{
    "name": "mtg-code",
    "displayName": "mtg-code",
    "description": "Build mtg decks using code.",
    "version": "0.0.1",
    "publisher": "PixR2",
    "engines": {
        "vscode": "^1.21.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:mtg"
    ],
    "main": "./out/extension",
    "contributes": {
        "languages": [
            {
                "id": "mtg",
                "extensions": [
                    ".mtg"
                ],
                "aliases": [
                    "mtg",
                    "mtg"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "mtg",
                "scopeName": "source.mtg",
                "path": "./syntaxes/mtg.tmLanguage.json"
            }
        ],
        "commands": []
    },
    "scripts": {
        "copy:dist": "mkdir -p out/carddb && mkdir -p out/mana-icons && cp carddb/AllCards.json out/carddb && cp mana-icons/* out/mana-icons",
        "vscode:prepublish": "npm run compile",
        "compile": "npm run copy:dist && tsc -p ./",
        "watch": "npm run copy:dist && tsc -watch -p ./",
        "postinstall": "node ./node_modules/vscode/bin/install",
        "test": "npm run compile && node ./node_modules/vscode/bin/test"
    },
    "devDependencies": {
        "typescript": "^2.6.1",
        "vscode": "^1.1.6",
        "tslint": "^5.8.0",
        "@types/node": "^7.0.43",
        "@types/mocha": "^2.2.42"
    },
    "dependencies": {
        "fuzzy": "^0.1.3",
        "image-download": "^1.1.0",
        "image-downloader": "^3.3.0",
        "resize-img": "^1.1.2",
        "web-request": "^1.0.7"
    }
}
